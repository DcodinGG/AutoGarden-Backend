# ─────────────────────────────────────────────
#  AutoGarden Backend — Environment Variables
#  Copy this file: cp .env.example .env
#  Fill in your values. NEVER commit .env to repo.
# ─────────────────────────────────────────────

# MQTT Broker (Mosquitto running on the same Raspberry Pi)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=autogarden
MQTT_PASSWORD=your_mqtt_password

# Google Gemini API
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap (Weather Forecast)
# Free account at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_key
OPENWEATHER_CITY=Madrid          # City where your garden is located
OPENWEATHER_UNITS=metric         # metric = Celsius
OPENWEATHER_LANG=en              # en = English

# Web dashboard server
PORT=3000

# SQLite database path
DB_PATH=./autogarden.db
