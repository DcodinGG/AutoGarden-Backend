# ─────────────────────────────────────────────
#  AutoGarden Backend — Variables de entorno
#  Copia este archivo: cp .env.example .env
#  Rellena tus valores. NUNCA subas .env al repo.
# ─────────────────────────────────────────────

# MQTT Broker (Mosquitto corriendo en la misma Raspberry Pi)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=autogarden
MQTT_PASSWORD=tu_password_mqtt

# Anthropic (Claude API)
# Obtén tu clave en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenWeatherMap (previsión meteorológica)
# Cuenta gratuita en: https://openweathermap.org/api
OPENWEATHER_API_KEY=tu_api_key_openweather
OPENWEATHER_CITY=Madrid          # Ciudad donde está tu jardín
OPENWEATHER_UNITS=metric         # metric = Celsius

# Servidor web del dashboard
PORT=3000

# Base de datos SQLite (ruta en la Raspberry Pi)
DB_PATH=./autogarden.db
